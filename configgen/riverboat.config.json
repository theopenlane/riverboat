    },
    "corejobs.PirschDomainConfig": {
      "properties": {
        "openlaneapihost": {
          "type": "string"
        },
        "openlaneapitoken": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "pirschclientid": {
          "type": "string"
        },
        "pirschclientsecret": {
          "type": "string"
        },
        "pirschthemeid": {
          "type": "string",
