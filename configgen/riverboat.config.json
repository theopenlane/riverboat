    "corejobs.ValidateCustomDomainWorker": {
      "properties": {
        "config": {
          "$ref": "#/$defs/corejobs.CustomDomainConfig",
          "description": "the configuration for custom domain validation"
        }
      },
      "additionalProperties": false,
